# PersonaChat Backend 환경 변수 설정

# 서버 포트 (기본값: 36000)
PORT=36000

# OpenRouter API 키 (필수)
OPENROUTER_API_KEY=sk-or-your-key-here

# 이미지 생성 (나노바나나/페르소나 아바타) — 둘 중 하나 설정
# Google Gemini: GEMINI_API_KEY만 설정 (NANOBANANA_API_BASE_URL 비우기)
#   예시 형식: AIzaSy... (Google AI Studio에서 발급)
# APIYI 등: NANOBANANA_API_KEY + NANOBANANA_API_BASE_URL (예: https://api.apiyi.com/v1beta)
#   예시 형식: sk-xxxxxxxxxxxxxxxx (APIYI 회원가입 후 발급)
GEMINI_API_KEY=
NANOBANANA_API_KEY=
NANOBANANA_API_BASE_URL=

# 이미지 생성 모델 (기본값: gemini-2.5-flash-image — 이미지 출력 지원 모델만 사용)
# gemini-2.0-flash-001 등은 이미지 출력 미지원 → 400 "response modalities: image" 오류 발생
# APIYI 사용 시: gemini-3.1-flash-image-preview 등
# GEMINI_IMAGE_MODEL=
# NANOBANANA_IMAGE_MODEL=

# 프론트엔드 URL (CORS 설정용)
FRONTEND_URL=http://localhost:5173
